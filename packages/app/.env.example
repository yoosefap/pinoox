APP_NAME="__PINX_DISPLAY_NAME__"
APP_ENV=development
APP_KEY=
APP_URL=http://127.0.0.1:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

PINX_PACKAGE=__PINX_PACKAGE__
SERVER_APP=__PINX_PACKAGE__
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

LOG_PATH=~storage/logs/app.log
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pinoox_app
DB_USERNAME=root
DB_PASSWORD=
DB_PREFIX=pinx_

SESSION_DRIVER=file
SESSION_SAVE_PATH=~storage/sessions

FILESYSTEM_DISK=local
